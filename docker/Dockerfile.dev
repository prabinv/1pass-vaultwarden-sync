FROM golang:1.26-alpine
RUN apk add --no-cache gcc musl-dev wget
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
RUN go install github.com/a-h/templ/cmd/templ@latest
RUN ARCH=$(uname -m) && \
    if [ "$ARCH" = "aarch64" ]; then BIN="tailwindcss-linux-arm64"; else BIN="tailwindcss-linux-x64"; fi && \
    wget -qO /usr/local/bin/tailwindcss \
      "https://github.com/tailwindlabs/tailwindcss/releases/download/v3.4.17/${BIN}" && \
    chmod +x /usr/local/bin/tailwindcss
COPY . .
CMD ["sh", "-c", "tailwindcss -i ./internal/web/static/css/input.css -o ./internal/web/static/css/tailwind.css --minify && templ generate ./... && CGO_ENABLED=1 go build -o /tmp/server ./cmd/server && /tmp/server"]
